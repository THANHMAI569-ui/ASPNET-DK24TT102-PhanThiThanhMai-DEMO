@model IReadOnlyList<FavoriteItemViewModel>
@{
    ViewData["Title"] = "Món yêu thích";
}

<h1 class="mb-4">Món yêu thích</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Bạn chưa có món yêu thích nào. Vào trang chi tiết món và bấm "Thêm yêu thích".</div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        @foreach (var recipe in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@(string.IsNullOrEmpty(recipe.ImageUrl) ? Url.Content("~/images/recipe-placeholder.svg") : recipe.ImageUrl)"
                         class="card-img-top" alt="@recipe.Name" style="height: 180px; object-fit: cover;"/>
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary align-self-start mb-2">@recipe.CategoryName</span>
                        <h5 class="card-title">@recipe.Name</h5>
                        <p class="card-text text-muted mt-auto">
                            @recipe.Region.ToDisplayName() &middot; @recipe.Difficulty.ToDisplayName()
                        </p>
                        <div class="d-flex gap-2">
                            <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-outline-primary btn-sm flex-fill">
                                Xem chi tiết
                            </a>
                            <form asp-controller="Favorite" asp-action="Toggle" method="post">
                                <input type="hidden" name="recipeId" value="@recipe.Id"/>
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path"/>
                                <button type="submit" class="btn btn-outline-danger btn-sm">Bỏ</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
