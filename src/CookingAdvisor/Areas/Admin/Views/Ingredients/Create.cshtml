@model IngredientFormViewModel
@{
    ViewData["Title"] = "Thêm nguyên liệu";
}

<h1 class="mb-4">Thêm nguyên liệu</h1>

<div class="col-12 col-md-6">
    <form asp-action="Create" method="post" class="card card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Unit" class="form-label"></label>
            <input asp-for="Unit" class="form-control" placeholder="kg, quả, bó..." />
            <span asp-validation-for="Unit" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Group" class="form-label"></label>
            <input asp-for="Group" class="form-control" placeholder="Thịt, Rau củ, Gia vị..." />
            <span asp-validation-for="Group" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
