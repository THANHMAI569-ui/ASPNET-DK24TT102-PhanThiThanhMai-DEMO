@model IReadOnlyList<IngredientListItemViewModel>
@{
    ViewData["Title"] = "Quản lý nguyên liệu";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Nguyên liệu</h1>
    <a asp-action="Create" class="btn btn-primary">+ Thêm nguyên liệu</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Chưa có nguyên liệu nào.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Đơn vị</th>
                <th>Nhóm</th>
                <th class="text-center">Dùng trong</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ingredient in Model)
            {
                <tr>
                    <td>@ingredient.Name</td>
                    <td>@ingredient.Unit</td>
                    <td>@ingredient.Group</td>
                    <td class="text-center">@ingredient.UsageCount món</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@ingredient.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@ingredient.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="Dashboard" asp-action="Index" class="btn btn-link">&larr; Về khu quản trị</a>
