@model IReadOnlyList<CategoryListItemViewModel>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Danh mục</h1>
    <a asp-action="Create" class="btn btn-primary">+ Thêm danh mục</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Chưa có danh mục nào.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Tên danh mục</th>
                <th class="text-center">Số món</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td class="text-center">@category.RecipeCount</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="Dashboard" asp-action="Index" class="btn btn-link">&larr; Về khu quản trị</a>
