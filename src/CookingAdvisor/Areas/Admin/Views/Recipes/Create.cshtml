@model RecipeFormViewModel
@{
    ViewData["Title"] = "Thêm món ăn";
}

<h1 class="mb-4">Thêm món ăn</h1>

<form asp-action="Create" method="post" class="card card-body">
    <partial name="_Form" model="Model" />
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
